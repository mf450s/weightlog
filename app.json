{
  "expo": {
    "name": "OpenWeights",
    "slug": "openweights",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "openweights",
    "splash": {
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.openweights.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090B"
      },
      "package": "com.openweights.app"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ]
  }
}
